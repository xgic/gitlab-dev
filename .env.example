# Configuration for local builds and future Compose consumers.
# Do not put production secrets or private production project paths here.

# GHCR image coordinates (public)
IMAGE_NAME=ghcr.io/xgic/xgic-gitlab
IMAGE_TAG=local

# Optional: non-production GitLab EE URL for integration tests (env-driven only)
# GITLAB_URL=
# GITLAB_TOKEN=
# GITLAB_TEST_NAMESPACE_PATH=
